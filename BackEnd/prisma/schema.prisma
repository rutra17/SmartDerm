generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. TABELA DE PACIENTES
// ==========================================
model Paciente {
  id         String     @id @default(uuid())
  username   String     @unique // O novo meio de autenticação (Login)
  senha      String     // Será guardada com hash (Bcrypt)
  nome       String
  email      String     @unique // Continua único, mas não é usado para login
  genero     String?
  cep        String?
  endereco   String?
  referencia String?
  cpf        String?    @unique // Exemplo de campo específico
  criadoEm   DateTime   @default(now())
  
  consultas  Consulta[]
}

// ==========================================
// 2. TABELA DE MÉDICOS
// ==========================================
model Medico {
  id         String     @id @default(uuid())
  username   String     @unique // O novo meio de autenticação (Login)
  senha      String
  nome       String
  email      String     @unique
  genero     String?
  cep        String?
  endereco   String?
  referencia String?
  crm        String     @unique // Campo obrigatório e específico para médicos
  criadoEm   DateTime   @default(now())
  
  laudos     Consulta[] // Consultas que este médico analisou
}

// ==========================================
// 3. TABELA DE CIENTISTAS
// ==========================================
model Cientista {
  id          String     @id @default(uuid())
  username    String     @unique // O novo meio de autenticação (Login)
  senha       String
  nome        String
  email       String     @unique
  genero      String?
  cep         String?
  endereco    String?
  referencia  String?
  instituicao String?    // Campo específico para cientistas/pesquisadores
  criadoEm    DateTime   @default(now())
}

// ==========================================
// TABELA DO CIENTISTA DE DADOS
// ==========================================
model Prompt {
  id           String   @id @default(uuid())
  titulo       String   // Ex: "Triagem Severa (Urgências)"
  chave        String   @unique // Ex: "urgencia" (usado para o Front-End identificar)
  instrucao    String   // O texto gigante com as regras para o Gemini
  ativo        Boolean  @default(true) // Permite ligar/desligar um prompt
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ==========================================
// 4. TABELA DE CONSULTAS (Triagem)
// ==========================================
model Consulta {
  id            String     @id @default(uuid())
  nome_paciente String     // Nome digitado no Modal de Nova Consulta
  pacienteId    String
  medicoId      String?    // Pode ser nulo até um médico assumir a consulta
  status        String     @default("pendente") // "pendente", "em_analise", "finalizada"
  laudoMedico   String?    @db.Text
  analiseGemini String?    @db.Text
  criadoEm      DateTime   @default(now())
  
  paciente      Paciente   @relation(fields: [pacienteId], references: [id])
  medico        Medico?    @relation(fields: [medicoId], references: [id])
  mensagens     Mensagem[]
}

// ==========================================
// 5. TABELA DE MENSAGENS E IMAGENS (Chat)
// ==========================================
model Mensagem {
  id               String   @id @default(uuid())
  consultaId       String
  role             String   // "user" ou "assistant"
  texto            String?  @db.Text
  imagem_url       String?  // Nome/URL da imagem guardada no MinIO
  ia_utilizada     String?  // "gemini", "simulacao", etc.
  prompt_utilizado String?  // "padrao", "severo", etc.
  criadoEm         DateTime @default(now())

  // Cascade: Se a consulta for deletada, as mensagens também serão
  consulta         Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
}